# Database
DATABASE_URL=postgresql+asyncpg://vector_ecm:vector_ecm@127.0.0.1:5433/vector_ecm
DATABASE_URL_SYNC=postgresql+psycopg2://vector_ecm:vector_ecm@127.0.0.1:5433/vector_ecm

# Embedding provider: "local" or "deepseek"
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# DeepSeek API (openai-compatible)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
# Optional dedicated embedding model if deepseek provides one:
# DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# LLM chat
LLM_PROVIDER=deepseek
CHAT_MODEL=deepseek-chat
CHAT_MAX_TOKENS=2048
CHAT_TEMPERATURE=0.7

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Search defaults
SEARCH_DEFAULT_TOP_K=5
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3
